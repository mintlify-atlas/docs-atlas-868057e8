  "keyFeatures": [
    "JWT-based authentication with refresh tokens and session management",
    "Real-time trip matching and driver assignment via WebSockets",
    "Complete trip lifecycle management from request to completion",
    "Driver availability tracking with geohash-based location indexing",
    "Multi-tier vehicle classification and dynamic pricing",
    "Wallet and payment transaction management",
    "Swagger API documentation with multiple doc sets",
    "Rate limiting and request throttling",
    "Idempotency key support for safe retries"
  ],
  "publicApiSurface": [
    "POST /api/auth/login - Authenticate and create session",
    "POST /api/auth/refresh - Refresh access token",
    "POST /api/auth/logout - Revoke session",
    "POST /api/trips - Create new trip request",
    "POST /api/trips/estimate - Get trip fare estimate",
    "GET /api/trips/:id - Get trip details",
    "GET /api/trips - List trips with pagination",
    "POST /api/trips/:id/assign/start - Start driver assignment",
    "PATCH /api/trips/assignments/:id/accept - Accept trip assignment",
    "POST /api/trips/:id/arriving - Driver arriving to pickup",
    "POST /api/trips/:id/start - Start trip in progress",
    "POST /api/trips/:id/complete - Complete trip",
    "WebSocket /driver-auth - Driver authentication gateway",
    "WebSocket /driver-availability - Driver location and status updates",
    "WebSocket /passenger - Passenger trip updates",
    "WebSocket /admin - Admin monitoring gateway"
  ]
}
